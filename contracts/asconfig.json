{
  "targets": {
    "debug": {
      "outFile": "build/LaunchToken.wasm",
      "textFile": "build/LaunchToken.wat",
      "use": ["abort=src/index/abort"]
    },
    "factory": {
      "outFile": "build/OPumpFactory.wasm",
      "textFile": "build/OPumpFactory.wat",
      "use": ["abort=src/factory-index/abort"]
    }
  },
  "options": {
    "transform": "@btc-vision/opnet-transform",
    "sourceMap": false,
    "optimizeLevel": 3,
    "shrinkLevel": 1,
    "converge": true,
    "noAssert": false,
    "enable": [
      "sign-extension",
      "mutable-globals",
      "nontrapping-f2i",
      "bulk-memory",
      "simd",
      "reference-types",
      "multi-value"
    ],
    "runtime": "stub",
    "memoryBase": 0,
    "initialMemory": 1,
    "exportStart": "start"
  }
}
